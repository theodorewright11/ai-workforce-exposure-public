# ---- Data ----
# Data IS committed (under /data/) so the dashboard backend image and the figure
# scripts have everything they need at build time. Only the regenerable bits below
# are ignored.

# ---- Generated figure outputs + run logs (regenerable) ----
paper_figures/results/
paper_figures/lib/**/results/
paper_figures/*.log

# ---- Python ----
venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# ---- Node / Next.js (dashboard frontend) ----
node_modules/
.next/
next-env.d.ts
*.tsbuildinfo

# ---- Internal agent/working docs: NEVER committed ----
# Planning + agent-instruction docs are local-only (kept off GitHub).
dashboard/PRD.md
dashboard/ARCHITECTURE.md
dashboard/CLAUDE.md

# ---- OS / editor ----
.DS_Store
.vscode/
.idea/
